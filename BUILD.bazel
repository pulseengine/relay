# ═══════════════════════════════════════════════════════════════
# Verus verification (Track 1: SMT/Z3)
# ═══════════════════════════════════════════════════════════════

verus_test(
    name = "relay_primitives_verus_test",
    srcs = [
        "crates/relay-primitives/src/lib.rs",
        "crates/relay-primitives/src/crc32.rs",
        "crates/relay-primitives/src/compare.rs",
        "crates/relay-primitives/src/persistence.rs",
        "crates/relay-primitives/src/rate_divide.rs",
        "crates/relay-primitives/src/time_gate.rs",
        "crates/relay-primitives/src/ccsds.rs",
        "crates/relay-primitives/src/merge.rs",
        "crates/relay-primitives/src/filter.rs",
    ],
    crate_name = "relay_primitives",
)

# Catch drift between src/ (Verus) and plain/ (Cargo) trees.
# verus-strip currently has bugs around `pub exec const` and backtick-escaped
# tokens in doc comments; until those are fixed upstream, plain/ is hand-
# maintained and this test enforces the structural correspondence.
verus_strip_test(
    name = "relay_primitives_strip_test",
    verus_srcs = [
        "crates/relay-primitives/src/crc32.rs",
        "crates/relay-primitives/src/compare.rs",
        "crates/relay-primitives/src/persistence.rs",
        "crates/relay-primitives/src/rate_divide.rs",
        "crates/relay-primitives/src/time_gate.rs",
        "crates/relay-primitives/src/ccsds.rs",
        "crates/relay-primitives/src/merge.rs",
        "crates/relay-primitives/src/filter.rs",
    ],
    plain_srcs = [
        "crates/relay-primitives/plain/src/crc32.rs",
        "crates/relay-primitives/plain/src/compare.rs",
        "crates/relay-primitives/plain/src/persistence.rs",
        "crates/relay-primitives/plain/src/rate_divide.rs",
        "crates/relay-primitives/plain/src/time_gate.rs",
        "crates/relay-primitives/plain/src/ccsds.rs",
        "crates/relay-primitives/plain/src/merge.rs",
        "crates/relay-primitives/plain/src/filter.rs",
    ],
)

verus_test(
    name = "relay_lc_verus_test",
    srcs = [
        "crates/relay-lc/src/lib.rs",
        "crates/relay-lc/src/engine.rs",
        # Primitives are brought in via #[path] in src/lib.rs so Verus
        # treats them as submodules of relay_lc. This is the interim
