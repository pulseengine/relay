    srcs = [
        "crates/relay-lc/src/lib.rs",
        "crates/relay-lc/src/engine.rs",
    ],
    crate_name = "relay_lc",
)

verus_test(
    name = "relay_sch_verus_test",
    srcs = [
        "crates/relay-sch/src/lib.rs",
        "crates/relay-sch/src/engine.rs",
    ],
    crate_name = "relay_sch",
)

verus_test(
    name = "relay_sc_verus_test",
    srcs = [
        "crates/relay-sc/src/lib.rs",
        "crates/relay-sc/src/engine.rs",
    ],
    crate_name = "relay_sc",
)

verus_test(
    name = "relay_hk_verus_test",
    srcs = [
        "crates/relay-hk/src/lib.rs",
        "crates/relay-hk/src/engine.rs",
    ],
