package pulseengine:relay-data-storage@0.1.0;

/// Data Storage (DS) — store SB messages to files.
///
/// Table-driven: Filter Table specifies which MsgIds to store.
/// File Table specifies naming conventions, size limits, sequencing.
world data-storage {
    import pulseengine:relay-common-types/types;
    import pulseengine:relay-software-bus/bus;
    import pulseengine:relay-tables/tables;
    import pulseengine:relay-events/events;
    import wasi:filesystem/types@0.2.3;
    import wasi:filesystem/preopens@0.2.3;

    /// Initialize: register filter/file tables, subscribe to SB.
    export init: func() -> result<_, string>;

    /// Process incoming messages and write to storage.
    export pulseengine:relay-software-bus/message-handler;
}
